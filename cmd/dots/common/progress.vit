space dots/cmd/common/progress

use core/io
use core/str

proc spinner(step: i32) -> string
{
    let frames = ["-", "\\", "|", "/"]
    let idx = step % 4
    give frames[idx]
}

proc show_progress(prefix: string, current: i32, total: i32) -> bool
{
    let pct = (current * 100) / total
    io.print(prefix + " " + str.from_i32(pct) + "%")

    give false
}
