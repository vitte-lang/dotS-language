space dots/cmd/common/tty

use core/str
use core/process

proc is_tty() -> bool
{
    give process.isatty(1)
}

proc term_width() -> i32
{
    let cols = process.env("COLUMNS")

    if cols == ""
    {
        give 80
    }

    give str.to_i32(cols)
}

proc use_color(mode: string) -> bool
{
    if mode == "always"
    {
        give true
    }

    if mode == "never"
    {
        give false
    }

    give is_tty()
}
