space dots/cmd/common/validate

use core/fs
use core/str

proc required_str(value: string, label: string) -> string
{
    if value == ""
    {
        give label + " is required"
    }

    give ""
}

proc in_enum(value: string, allowed: [string], label: string) -> string
{
    for a in allowed
    {
        if value == a
        {
            give ""
        }
    }

    give label + " must be one of: " + str.join(allowed, "|")
}

proc in_range_i64(value: i64, min: i64, max: i64, label: string) -> string
{
    if value < min  or  value > max
    {
        give label + " out of range"
    }

    give ""
}

proc path_exists(path: string, label: string) -> string
{
    if not fs.exists(path)
    {
        give label + " not found: " + path
    }

    give ""
}

proc validate_network_options(retries: i32, jitter_ms: i64, cb_threshold: i32, timeout_ms: i64) -> string
{
    if retries <= 0 { give "--retries must be > 0" }
    if jitter_ms < 0 { give "--jitter-ms must be >= 0" }
    if cb_threshold <= 0 { give "--cb-threshold must be > 0" }
    if timeout_ms < 0 { give "--timeout-ms must be >= 0" }
    give ""
}
