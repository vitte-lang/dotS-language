(* ========================================= *)
(* DotS Script Language Grammar              *)
(* Minimal Script-Oriented Syntax            *)
(* ========================================= *)

program         = { statement } ;

(* ----------------------------------------- *)
(* Statements                                *)
(* ----------------------------------------- *)

statement       = assignment
                | function_def
                | function_call
                | control
                | error_stmt
                | expression ;

(* ----------------------------------------- *)
(* Assignment                                *)
(* ----------------------------------------- *)

assignment      = "set" "." variable "." expression
                | "let" "." variable "." expression
                | "const" "." variable "." expression ;

(* ----------------------------------------- *)
(* Functions                                 *)
(* ----------------------------------------- *)

function_def    = "fn" "." qualified_identifier { "." parameter } ;

parameter       = variable ;

function_call   = "call" "." qualified_identifier { "." argument } ;

return_stmt     = "ret" [ "." argument ] ;

(* ----------------------------------------- *)
(* Control flow                              *)
(* ----------------------------------------- *)

control         = if_stmt
                | loop_stmt
                | while_stmt
                | for_stmt
                | break_stmt
                | continue_stmt ;

if_stmt         = "if" "." expression ;

elif_stmt       = "elif" "." expression ;

else_stmt       = "else" ;

loop_stmt       = "loop" "." expression ;

while_stmt      = "while" "." expression ;

for_stmt        = "for" "." variable "." expression ;

break_stmt      = "break" ;

continue_stmt   = "continue" ;

(* ----------------------------------------- *)
(* Error handling                            *)
(* ----------------------------------------- *)

error_stmt      = try_stmt
                | catch_stmt
                | throw_stmt ;

try_stmt        = "try" ;

catch_stmt      = "catch" ;

throw_stmt      = "throw" "." expression ;

(* ----------------------------------------- *)
(* Expressions                               *)
(* ----------------------------------------- *)

expression      = pipeline ;

pipeline        = value { "." value } ;

value           = identifier
                | variable
                | literal
                | function_call ;

argument        = expression ;

(* ----------------------------------------- *)
(* Modules / imports                         *)
(* ----------------------------------------- *)

module_stmt     = "module" "." qualified_identifier ;

use_stmt        = "use" "." qualified_identifier ;

import_stmt     = "import" "." qualified_identifier ;

(* ----------------------------------------- *)
(* Variables                                 *)
(* ----------------------------------------- *)

variable        = "$" identifier ;

(* ----------------------------------------- *)
(* Literals                                  *)
(* ----------------------------------------- *)

literal         = string
                | number
                | boolean ;

string          = '"' { character } '"' ;

number          = digit { digit } [ "." digit { digit } ] ;

boolean         = "true" | "false" ;

(* ----------------------------------------- *)
(* Identifiers                               *)
(* ----------------------------------------- *)

identifier      = letter { letter | digit | "_" } ;

qualified_identifier = identifier { "." identifier } ;

(* ----------------------------------------- *)
(* Characters                                *)
(* ----------------------------------------- *)

letter          = "a"…"z" | "A"…"Z" ;

digit           = "0"…"9" ;

character       = ? any unicode char except " ? ;

(* ----------------------------------------- *)
(* Whitespace and comments                   *)
(* ----------------------------------------- *)

whitespace      = " " | "\t" | "\n" | "\r" ;

comment         = "#" { character } ;
