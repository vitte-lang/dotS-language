space bench.runtime
pull core.time

const RUNS: i64 = 5
const ITERS: i64 = 100

proc main() -> i64
{
    let run: i64 = 0
    let sum: i64 = 0

    loop while run < RUNS
    {
        let i: i64 = 0
        loop while i < ITERS
        {
            sum = sum + 1
            i = i + 1
        }
        run = run + 1
    }

    give sum
}
