space stdlib/system/env

pull core/process
pull core/str

proc get(name: string) -> string
{
    give process.env(name)
}

proc set(name: string, value: string) -> void
{
    process.set_env(name, value)
}

proc has(name: string) -> bool
{
    give process.env(name) != ""
}

proc get_i64(name: string, fallback: i64) -> i64
{
    let raw = process.env(name)
    if raw == "" { give fallback }
    give str.to_i64(raw)
}
