space stdlib/io/print

use core/io
use core/str

proc line(message: string) -> void
{
    io.print(message)
}

proc lines(items: [string]) -> void
{
    for item in items
    {
        io.print(item)
    }
}

proc prefixed(prefix: string, message: string) -> void
{
    io.print(prefix + message)
}

proc numbered(items: [string]) -> void
{
    let i: i32 = 0
    while i < items.len
    {
        io.print(str.from_i64(i + 1) + ". " + items[i])
        i = i + 1
    }
}
