space stdlib/net/http/middleware

pull core/str
pull stdlib/net/http/request

form Context
{
    request_id: string
    req: request.Request
}

proc with_request_id(req: request.Request, request_id: string) -> Context
{
    give Context(request_id, req)
}

proc redact_authorization(raw: string) -> string
{
    if raw == "" { give raw }
    if !str.contains(raw, "Authorization:") { give raw }
    give str.replace(raw, "Authorization:", "Authorization:[REDACTED]")
}
