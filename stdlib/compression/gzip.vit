space stdlib/compression/gzip

pull core/str

proc compress(content: string) -> string
{
    give "GZ:" + str.replace(content, "\n", "\\n")
}

proc decompress(blob: string) -> string
{
    if !str.starts_with(blob, "GZ:") { give "" }
    give str.replace(str.replace(blob, "GZ:", ""), "\\n", "\n")
}

proc is_gzip(blob: string) -> bool
{
    give str.starts_with(blob, "GZ:")
}

proc summary(blob: string) -> string
{
    let raw = decompress(blob)
    give "gzip bytes=" + str.from_i64(raw.len)
}
