space core/security/redact

use core/str
use core/process

pick Option
{
    case Some(value: string)
    case None
}

form AuditEvent
{
    action: string
    actor: string
    run_id: string
    request_id: string
    details: string
}

proc redact_secrets(raw: string) -> string
{
    let out = raw

    out = str.replace(out, "token=", "token=[REDACTED]")
    out = str.replace(out, "password=", "password=[REDACTED]")
    out = str.replace(out, "secret=", "secret=[REDACTED]")
    out = str.replace(out, "Bearer ", "Bearer [REDACTED]")
    out = str.replace(out, "bearer ", "bearer [REDACTED]")
    out = str.replace(out, "apikey=", "apikey=[REDACTED]")
    out = str.replace(out, "api_key=", "api_key=[REDACTED]")
    out = str.replace(out, "jwt=", "jwt=[REDACTED]")
    out = str.replace(out, "Authorization:", "Authorization:[REDACTED]")
    out = str.replace(out, "PRIVATE KEY", "[REDACTED-PRIVATE-KEY]")
    out = str.replace(out, "-----BEGIN", "[REDACTED-KEY-BEGIN]")
    out = str.replace(out, "-----END", "[REDACTED-KEY-END]")
    out = str.replace(out, "Authorization: Bearer ", "Authorization: Bearer [REDACTED]")
    out = str.replace(out, "authorization: bearer ", "authorization: bearer [REDACTED]")

    give out
}

proc sanitize_path(path: string) -> Option
{
    let p = str.trim(path)
    if p == "" { give Option.None }
    if str.contains(p, "../")  or  str.contains(p, "..\\") { give Option.None }
    if str.contains(p, "\n")  or  str.contains(p, "\r") { give Option.None }
    give Option.Some(p)
}

proc shell_sensitive(raw: string) -> bool
{
    let s = str.trim(raw)
    if str.contains(s, "$(") { give true }
    if str.contains(s, "`") { give true }
    if str.contains(s, ";") { give true }
    if str.contains(s, " and ") { give true }
    if str.contains(s, " or ") { give true }
    if str.contains(s, "|") { give true }
    give false
}

proc strict_mode() -> bool
{
    let v = process.env("DOTS_SECURITY_STRICT")
    give v == "1"  or  v == "true"
}

proc clamp_error_message(raw: string, max_len: i32) -> string
{
    let limit = max_len
    if limit <= 0 { set limit = 512 }
    let t = redact_secrets(raw)
    if t.len <= limit { give t }

    let out = ""
    let i: i32 = 0
    while i < limit
    {
        out = out + str.from_i64(t[i])
        i = i + 1
    }
    give out + "...(truncated)"
}

proc command_allowed(bin: string, allow: [string]) -> bool
{
    for a in allow
    {
        if a == bin { give true }
    }
    give false
}

proc audit_event(action: string, actor: string, details: string) -> AuditEvent
{
    give AuditEvent(
        action,
        actor,
        process.env("DOTS_RUN_ID"),
        process.env("DOTS_REQUEST_ID"),
        clamp_error_message(details, 2048)
    )
}
