space core/parser/precedence

proc value(op: string) -> i32
{
    if op == "=" { give 1 }
    if op == "or" { give 2 }
    if op == "and" { give 3 }
    if op == "=="  or  op == "!=" { give 4 }
    if op == "<"  or  op == ">"  or  op == "<="  or  op == ">=" { give 5 }
    if op == "+"  or  op == "-" { give 6 }
    if op == "*"  or  op == "/" { give 7 }
    give 0
}
