space core/parser

use core/str
use core/process
use core/lexer
use core/lexer/token
use core/lexer/token_kind
use core/parser/context
use core/parser/diagnostics
use core/parser/recovery
use core/diagnostics

form AstNode
{
    id: i64
    kind: string
    value: string
    children: [AstNode]
    line: i32
    col: i32
}

form ParseResult
{
    ok: bool
    root: AstNode
    diagnostics: [diagnostics.Diagnostic]
}

proc make_node(id: i64, kind: string, value: string, children: [AstNode], line: i32, col: i32) -> AstNode
{
    give AstNode(id, kind, value, children, line, col)
}

proc trace_enabled() -> bool
{
    let v = process.env("DOTS_PARSE_TRACE")
    give v == "1"  or  v == "true"
}

proc token_line(t: Option[token.Token]) -> i32
{
    if t == null { give 1 }
    give t.sp.start_pos.line
}

proc token_col(t: Option[token.Token]) -> i32
{
    if t == null { give 1 }
    give t.sp.start_pos.col
}

proc parse_identifier(ctx: context.ParseContext, next_id: i64, expected: string) -> (AstNode, context.ParseContext, i64)
{
    let t = context.peek(ctx, 0)
    if t != null  and  t.kind == token_kind.TK_IDENT
    {
        let n = make_node(next_id, "identifier", t.lexeme, [], t.sp.start_pos.line, t.sp.start_pos.col)
        give (n, context.bump(ctx), next_id + 1)
    }

    ctx.diagnostics = ctx.diagnostics.push(diagnostics.missing_token(token_line(t), token_col(t), expected))
    let n2 = make_node(next_id, "missing", expected, [], token_line(t), token_col(t))
    give (n2, ctx, next_id + 1)
}

proc parse_qualified_identifier(ctx: context.ParseContext, next_id: i64, expected: string) -> (AstNode, context.ParseContext, i64)
{
    let head, c1, id1 = parse_identifier(ctx, next_id + 1, expected)
    let parts: [AstNode] = [head]
    let raw = head.value
    let cur = c1
    let nid = id1

    while true
    {
        let dot = context.peek(cur, 0)
        let nxt = context.peek(cur, 1)
        if dot == null  or  dot.kind != token_kind.TK_DOT { break }
        if nxt == null  or  nxt.kind != token_kind.TK_IDENT { break }

        cur = context.bump(cur)
        let seg, c2, id2 = parse_identifier(cur, nid, expected)
        parts = parts.push(seg)
        raw = raw + "." + seg.value
        cur = c2
        nid = id2
    }

    let n = make_node(next_id, "qualified_identifier", raw, parts, head.line, head.col)
    give (n, cur, nid)
}

proc parse_dot(ctx: context.ParseContext) -> context.ParseContext
{
    let t = context.peek(ctx, 0)
    if t != null  and  t.kind == token_kind.TK_DOT
    {
        give context.bump(ctx)
    }

    ctx.diagnostics = ctx.diagnostics.push(diagnostics.missing_token(token_line(t), token_col(t), "."))
    give ctx
}

proc parse_variable(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let t = context.peek(ctx, 0)
    if t == null
    {
        let n = make_node(next_id, "missing", "$identifier", [], 1, 1)
        give (n, ctx, next_id + 1)
    }

    if t.kind != token_kind.TK_DOLLAR
    {
        ctx.diagnostics = ctx.diagnostics.push(diagnostics.unexpected_token(t, "$identifier"))
        let n2 = make_node(next_id, "error", t.lexeme, [], t.sp.start_pos.line, t.sp.start_pos.col)
        give (n2, context.bump(ctx), next_id + 1)
    }

    let c1 = context.bump(ctx)
    let name, c2, id2 = parse_identifier(c1, next_id + 1, "identifier")
    let n3 = make_node(next_id, "variable", "$" + name.value, [name], t.sp.start_pos.line, t.sp.start_pos.col)
    give (n3, c2, id2)
}

proc parse_function_call(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let kw = context.peek(ctx, 0)
    let c1 = context.bump(ctx)
    let c2 = parse_dot(c1)
    let callee, c3, id3 = parse_qualified_identifier(c2, next_id + 1, "function name")

    let args: [AstNode] = [callee]
    let cur = c3
    let nid = id3

    while true
    {
        let t = context.peek(cur, 0)
        if t == null  or  t.kind != token_kind.TK_DOT { break }

        cur = context.bump(cur)
        let a, c4, id4 = parse_value(cur, nid)
        args = args.push(a)
        cur = c4
        nid = id4
    }

    let line = token_line(kw)
    let col = token_col(kw)
    let n = make_node(next_id, "function_call", callee.value, args, line, col)
    give (n, cur, nid)
}

proc parse_value(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let t = context.peek(ctx, 0)
    if t == null
    {
        let n = make_node(next_id, "missing", "<eof>", [], 1, 1)
        give (n, ctx, next_id + 1)
    }

    if t.kind == token_kind.TK_NUMBER
    {
        give (make_node(next_id, "number", t.lexeme, [], t.sp.start_pos.line, t.sp.start_pos.col), context.bump(ctx), next_id + 1)
    }

    if t.kind == token_kind.TK_STRING
    {
        give (make_node(next_id, "string", t.lexeme, [], t.sp.start_pos.line, t.sp.start_pos.col), context.bump(ctx), next_id + 1)
    }

    if t.kind == token_kind.TK_IDENT
    {
        let k = "identifier"
        if t.lexeme == "true"  or  t.lexeme == "false" { k = "boolean" }
        give (make_node(next_id, k, t.lexeme, [], t.sp.start_pos.line, t.sp.start_pos.col), context.bump(ctx), next_id + 1)
    }

    if t.kind == token_kind.TK_DOLLAR
    {
        give parse_variable(ctx, next_id)
    }

    if t.kind == token_kind.TK_KEYWORD  and  t.lexeme == "call"
    {
        give parse_function_call(ctx, next_id)
    }

    ctx.diagnostics = ctx.diagnostics.push(diagnostics.unexpected_token(t, "value"))
    give (make_node(next_id, "error", t.lexeme, [], t.sp.start_pos.line, t.sp.start_pos.col), context.bump(ctx), next_id + 1)
}

proc parse_expression(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let lhs, c1, id1 = parse_value(ctx, next_id)
    let left = lhs
    let cur = c1
    let nid = id1

    while true
    {
        let t = context.peek(cur, 0)
        if t == null  or  t.kind != token_kind.TK_DOT { break }
        let t2 = context.peek(cur, 1)
        if t2 == null  or  t2.kind == token_kind.TK_NEWLINE  or  t2.kind == token_kind.TK_EOF
        {
            cur.diagnostics = cur.diagnostics.push(diagnostics.missing_token(token_line(t), token_col(t), "value"))
            break
        }

        cur = context.bump(cur)
        let rhs, c2, id2 = parse_value(cur, nid)
        left = make_node(nid, "pipeline", "", [left, rhs], left.line, left.col)
        cur = c2
        nid = id2 + 1
    }

    give (left, cur, nid)
}

proc parse_assignment(ctx: context.ParseContext, next_id: i64, kw: string) -> (AstNode, context.ParseContext, i64)
{
    let k = context.peek(ctx, 0)
    let c1 = context.bump(ctx)
    let c2 = parse_dot(c1)
    let v, c3, id3 = parse_variable(c2, next_id + 1)
    let c4 = parse_dot(c3)
    let ex, c5, id5 = parse_expression(c4, id3)
    let n = make_node(next_id, "assignment_" + kw, kw, [v, ex], token_line(k), token_col(k))
    give (n, c5, id5)
}

proc parse_function_def(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let kw = context.peek(ctx, 0)
    let c1 = context.bump(ctx)
    let c2 = parse_dot(c1)
    let name, c3, id3 = parse_identifier(c2, next_id + 1, "function name")

    let params: [AstNode] = [name]
    let cur = c3
    let nid = id3

    while true
    {
        let t = context.peek(cur, 0)
        if t == null  or  t.kind != token_kind.TK_DOT { break }

        cur = context.bump(cur)
        let p, c4, id4 = parse_variable(cur, nid)
        params = params.push(p)
        cur = c4
        nid = id4
    }

    let n = make_node(next_id, "function_def", name.value, params, token_line(kw), token_col(kw))
    give (n, cur, nid)
}

proc parse_keyword_stmt(ctx: context.ParseContext, next_id: i64, kind: string, with_expr: bool) -> (AstNode, context.ParseContext, i64)
{
    let kw = context.peek(ctx, 0)
    let cur = context.bump(ctx)
    let raw = ""
    if kw != null { raw = kw.lexeme }

    if not with_expr
    {
        give (make_node(next_id, kind, raw, [], token_line(kw), token_col(kw)), cur, next_id + 1)
    }

    let c2 = parse_dot(cur)
    let ex, c3, id3 = parse_expression(c2, next_id + 1)
    let n = make_node(next_id, kind, raw, [ex], token_line(kw), token_col(kw))
    give (n, c3, id3)
}

proc parse_for_stmt(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let kw = context.peek(ctx, 0)
    let c1 = context.bump(ctx)
    let c2 = parse_dot(c1)
    let v, c3, id3 = parse_variable(c2, next_id + 1)
    let c4 = parse_dot(c3)
    let ex, c5, id5 = parse_expression(c4, id3)
    let n = make_node(next_id, "for_stmt", "for", [v, ex], token_line(kw), token_col(kw))
    give (n, c5, id5)
}

proc parse_module_stmt(ctx: context.ParseContext, next_id: i64, kind: string) -> (AstNode, context.ParseContext, i64)
{
    let kw = context.peek(ctx, 0)
    let c1 = context.bump(ctx)
    let c2 = parse_dot(c1)
    let name, c3, id3 = parse_qualified_identifier(c2, next_id + 1, "identifier")
    let n = make_node(next_id, kind, name.value, [name], token_line(kw), token_col(kw))
    give (n, c3, id3)
}

proc parse_return_stmt(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let kw = context.peek(ctx, 0)
    let cur = context.bump(ctx)
    let t = context.peek(cur, 0)

    if t != null  and  t.kind == token_kind.TK_DOT
    {
        let c1 = context.bump(cur)
        let ex, c2, id2 = parse_expression(c1, next_id + 1)
        let n = make_node(next_id, "return_stmt", "ret", [ex], token_line(kw), token_col(kw))
        give (n, c2, id2)
    }

    give (make_node(next_id, "return_stmt", "ret", [], token_line(kw), token_col(kw)), cur, next_id + 1)
}

proc parse_statement(ctx: context.ParseContext, next_id: i64) -> (AstNode, context.ParseContext, i64)
{
    let t = context.peek(ctx, 0)
    if t == null
    {
        let n = make_node(next_id, "eof", "", [], 1, 1)
        give (n, ctx, next_id + 1)
    }

    if t.kind == token_kind.TK_KEYWORD
    {
        if t.lexeme == "set"  or  t.lexeme == "let"  or  t.lexeme == "const" { give parse_assignment(ctx, next_id, t.lexeme) }
        if t.lexeme == "fn" { give parse_function_def(ctx, next_id) }
        if t.lexeme == "call" { give parse_function_call(ctx, next_id) }
        if t.lexeme == "ret" { give parse_return_stmt(ctx, next_id) }

        if t.lexeme == "if" { give parse_keyword_stmt(ctx, next_id, "if_stmt", true) }
        if t.lexeme == "elif" { give parse_keyword_stmt(ctx, next_id, "elif_stmt", true) }
        if t.lexeme == "else" { give parse_keyword_stmt(ctx, next_id, "else_stmt", false) }
        if t.lexeme == "loop" { give parse_keyword_stmt(ctx, next_id, "loop_stmt", true) }
        if t.lexeme == "while" { give parse_keyword_stmt(ctx, next_id, "while_stmt", true) }
        if t.lexeme == "for" { give parse_for_stmt(ctx, next_id) }
        if t.lexeme == "break" { give parse_keyword_stmt(ctx, next_id, "break_stmt", false) }
        if t.lexeme == "continue" { give parse_keyword_stmt(ctx, next_id, "continue_stmt", false) }

        if t.lexeme == "try" { give parse_keyword_stmt(ctx, next_id, "try_stmt", false) }
        if t.lexeme == "catch" { give parse_keyword_stmt(ctx, next_id, "catch_stmt", false) }
        if t.lexeme == "throw" { give parse_keyword_stmt(ctx, next_id, "throw_stmt", true) }

        if t.lexeme == "module" { give parse_module_stmt(ctx, next_id, "module_stmt") }
        if t.lexeme == "use" { give parse_module_stmt(ctx, next_id, "use_stmt") }
        if t.lexeme == "import" { give parse_module_stmt(ctx, next_id, "import_stmt") }
    }

    if t.kind == token_kind.TK_IDENT
    {
        let kd = diagnostics.keyword_typo(t)
        if kd != null
        {
            ctx.diagnostics = ctx.diagnostics.push(kd)
        }
    }

    let ex, c1, id1 = parse_expression(ctx, next_id + 1)
    let n = make_node(next_id, "stmt_expr", "", [ex], ex.line, ex.col)
    give (n, c1, id1)
}

proc parse(text: string) -> ParseResult
{
    let lexed = lexer.lex(text)
    let ctx = context.new(lexed.tokens, trace_enabled())
    let cur = ctx

    let items: [AstNode] = []
    let nid: i64 = 1

    while true
    {
        let t = context.peek(cur, 0)
        if t == null  or  t.kind == token_kind.TK_EOF { break }

        if t.kind == token_kind.TK_NEWLINE
        {
            cur = context.bump(cur)
            continue
        }

        let n, c2, id2 = parse_statement(cur, nid)
        items = items.push(n)
        cur = c2
        nid = id2

        let nt = context.peek(cur, 0)
        if nt != null  and  nt.kind == token_kind.TK_NEWLINE
        {
            cur = context.bump(cur)
        }
        else if nt != null  and  nt.kind != token_kind.TK_EOF
        {
            cur = recovery.sync(cur)
            let nt2 = context.peek(cur, 0)
            if nt2 != null  and  nt2.kind == token_kind.TK_NEWLINE
            {
                cur = context.bump(cur)
            }
        }
    }

    let root = make_node(0, "program", "", items, 1, 1)
    let diags = lexed.diagnostics
    for d in cur.diagnostics
    {
        diags = diags.push(d)
    }

    give ParseResult(diags.len == 0, root, diags)
}

proc ast_json(n: AstNode) -> string
{
    let kids = ""
    let i: i32 = 0
    while i < n.children.len
    {
        if i > 0 { kids = kids + "," }
        kids = kids + ast_json(n.children[i])
        i = i + 1
    }

    give "{" +
        "\"id\":" + str.from_i64(n.id) + "," +
        "\"kind\":\"" + str.replace(n.kind, "\"", "'") + "\"," +
        "\"value\":\"" + str.replace(n.value, "\"", "'") + "\"," +
        "\"line\":" + str.from_i64(n.line) + "," +
        "\"col\":" + str.from_i64(n.col) + "," +
        "\"children\":[" + kids + "]" +
    "}"
}

proc ast_json_stable(root: AstNode) -> string
{
    give "{\"schema_version\":\"1.1.0\",\"ast\":" + ast_json(root) + "}"
}
