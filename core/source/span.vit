space core/source/span

form Position
{
    line: i32
    col: i32
}

form Span
{
    start: i64
    end: i64
    start_pos: Position
    end_pos: Position
}

proc make(start: i64, end: i64, sline: i32, scol: i32, eline: i32, ecol: i32) -> Span
{
    give Span(start, end, Position(sline, scol), Position(eline, ecol))
}
