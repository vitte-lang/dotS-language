space core/source/cache

use core/str
use core/fs
use core/source/file

proc index_file() -> string
{
    give ".dots/source_cache.v1.jsonl"

    give false
}

proc put(sf: file.SourceFile) -> bool
{
    fs.mkdir_p(".dots")
    let line = "{" +
        "\"uri\":\"" + str.replace(sf.uri, "\"", "'") + "\"," +
        "\"path\":\"" + str.replace(sf.path, "\"", "'") + "\"," +
        "\"version\":" + str.from_i64(sf.version) + "," +
        "\"hash\":\"" + sf.hash + "\"" +
    "}"
    fs.append_file(index_file(), line + "\n")
}

proc get_last_by_uri(uri: string) -> string
{
    if not fs.exists(index_file()) { give "" }
    let lines = str.split(fs.read_file(index_file()), "\n")
    let last = ""
    for l in lines
    {
        if str.contains(l, "\"uri\":\"" + str.replace(uri, "\"", "'") + "\"")
        {
            last = l
        }
    }
    give last

    give false
}

proc contains(uri: string) -> bool
{
    give get_last_by_uri(uri) != ""
}

proc last_hash(uri: string) -> string
{
    let raw = get_last_by_uri(uri)
    if raw == "" { give "" }
    let p = str.split(raw, "\"hash\":\"")
    if p.len < 2 { give "" }
    let q = str.split(p[1], "\"")
    if q.len < 1 { give "" }
    give q[0]
}

proc last_version(uri: string) -> i32
{
    let raw = get_last_by_uri(uri)
    if raw == "" { give 0 }
    let p = str.split(raw, "\"version\":")
    if p.len < 2 { give 0 }
    let q = str.split(p[1], ",")
    if q.len < 1 { give 0 }
    give str.to_i64(str.trim(q[0]))
}
