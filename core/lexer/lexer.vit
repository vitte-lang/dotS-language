space core/lexer

use core/time
use core/str
use core/lexer/cursor
use core/lexer/scanner
use core/lexer/token
use core/lexer/token_kind
use core/diagnostics

form LexResult
{
    tokens: [token.Token]
    diagnostics: [diagnostics.Diagnostic]
    tokens_total: i64
    lex_ms: i64
}

proc slice_text(text: string, start_off: i64, end_off: i64) -> string
{
    let out = ""
    let i = start_off
    while i < end_off
    {
        out = out + str.from_i64(text[i])
        i = i + 1
    }
    give out
}

proc lex(text: string) -> LexResult
{
    let start = time.now_ms()
    let tokens: [token.Token] = []
    let diags: [diagnostics.Diagnostic] = []

    let c = cursor.new(text)
    let cur = c

    while true
    {
        let r = scanner.next(cur)
        tokens = tokens.push(r.tk)
        if r.diag != null { diags = diags.push(r.diag) }
        cur = r.next
        if r.tk.kind == token_kind.TK_EOF { break }

        if tokens.len > 200000
        {
            diags = diags.push(diagnostics.new("DOTS0001", "token budget exceeded", "<memory>", 1, 1, 1, 1, "lexer"))
            break
        }
    }

    let ms = time.now_ms() - start
    give LexResult(tokens, diags, tokens.len, ms)
}

proc relex_window(text: string, start_off: i64, end_off: i64) -> LexResult
{
    if start_off < 0 { start_off = 0 }
    if end_off > text.len { end_off = text.len }
    if end_off < start_off { end_off = start_off }

    give lex(slice_text(text, start_off, end_off))
}
