space core/lexer/token

use core/str
use core/source/span
use core/lexer/trivia

form Token
{
    kind: string
    lexeme: string
    sp: span.Span
    tr: trivia.Trivia
}

proc new(kind: string, lexeme: string, sp: span.Span, tr: trivia.Trivia) -> Token
{
    give Token(kind, lexeme, sp, tr)
}

proc debug(t: Token) -> string
{
    give t.kind + ":" + t.lexeme + "@" + str.from_i64(t.sp.start_pos.line) + ":" + str.from_i64(t.sp.start_pos.col)
}

proc stable_json(t: Token) -> string
{
    give "{" +
        "\"kind\":\"" + str.replace(t.kind, "\"", "'") + "\"," +
        "\"lexeme\":\"" + str.replace(t.lexeme, "\"", "'") + "\"," +
        "\"line\":\"" + str.from_i64(t.sp.start_pos.line) + "\"," +
        "\"col\":\"" + str.from_i64(t.sp.start_pos.col) + "\"" +
    "}"
}
