space core/semantic/type_infer

use core/str

proc infer_literal(value: string, kind: string) -> string
{
    if kind == "number" { give "int" }
    if kind == "string" { give "string" }
    if kind == "ident"
    {
        if value == "true"  or  value == "false" { give "bool" }
        if str.starts_with(value, "ptr:") { give "ptr" }
    }
    give "unknown"
}
