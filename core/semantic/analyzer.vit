space core/semantic

use core/str
use core/process
use core/diagnostics
use core/parser
use core/semantic/scope
use core/semantic/resolver
use core/semantic/symbol_table
use modules/loader/resolver
use modules/loader/stdlib_catalog

const MAX_PACKAGE_SUGGESTIONS_DEFAULT: i32 = 8
const MAX_PACKAGE_QUICKFIXES_DEFAULT: i32 = 3

form AnalysisResult
{
    ok: bool
    symbols: symbol_table.SymbolTable
    diagnostics: [diagnostics.Diagnostic]
}

proc empty_strings() -> [string]
{
    let out: [string] = []
    give out
}

proc empty_i32s() -> [i32]
{
    let out: [i32] = []
    give out
}

proc empty_diagnostics() -> [diagnostics.Diagnostic]
{
    let out: [diagnostics.Diagnostic] = []
    give out
}

proc last_qualified_segment(raw: string) -> string
{
    if not str.contains(raw, ".") { give raw }
    let parts = str.split(raw, ".")
    if parts.len == 0 { give raw }
    give parts[parts.len - 1]
}

proc symbol_exists(sym: symbol_table.SymbolTable, name: string) -> bool
{
    if name == "" { give false }
    if symbol_table.find_any(sym, name) != null { give true }
    let tail = last_qualified_segment(name)
    if tail != name  and  symbol_table.find_any(sym, tail) != null { give true }
    give false
}

proc list_has(items: [string], v: string) -> bool
{
    let it: string = ""
    let i: i32 = 0
    while i < items.len
    {
        it = items[i]
        if it == v { give true }
        i = i + 1
    }
    give false
}

proc push_unique(items: [string], v: string) -> [string]
{
    if v == "" { give items }
    if list_has(items, v) { give items }
    give items.push(v)
}

proc clamp_i32(v: i32, lo: i32, hi: i32) -> i32
{
    if v < lo { give lo }
    if v > hi { give hi }
    give v
}

proc suggestion_limit() -> i32
{
    let raw = process.env("DOTS_SUGGEST_MAX")
    if raw == "" { give MAX_PACKAGE_SUGGESTIONS_DEFAULT }
    let n = str.to_i64(raw)
    give clamp_i32(n, 1, 32)
}

proc quickfix_limit() -> i32
{
    let raw = process.env("DOTS_SUGGEST_QUICKFIX_MAX")
    if raw == "" { give MAX_PACKAGE_QUICKFIXES_DEFAULT }
    let n = str.to_i64(raw)
    give clamp_i32(n, 1, 8)
}

proc unquote(raw: string) -> string
{
    if str.starts_with(raw, "\"")  and  str.ends_with(raw, "\"")  and  raw.len >= 2
    {
        let p = str.split(raw, "\"")
        if p.len >= 2 { give p[1] }
    }
    if str.starts_with(raw, "'")  and  str.ends_with(raw, "'")  and  raw.len >= 2
    {
        let p2 = str.split(raw, "'")
        if p2.len >= 2 { give p2[1] }
    }
    give raw
}

proc package_candidate_pool() -> [string]
{
    let pool = empty_strings()
    let std_items = stdlib_catalog.candidates()
    let s: string = ""
    let i: i32 = 0
    while i < std_items.len
    {
        s = std_items[i]
        pool = push_unique(pool, s)
        i = i + 1
    }
    let pkgs = resolver.discover_packages("")
    let p: string = ""
    let j: i32 = 0
    while j < pkgs.len
    {
        p = pkgs[j]
        pool = push_unique(pool, p)
        j = j + 1
    }
    give stdlib_catalog.sort_strings(pool)
}

proc pkg_is_stdlib(c: string) -> bool
{
    give stdlib_catalog.looks_stdlib(c)
}

proc min3(a: i32, b: i32, c: i32) -> i32
{
    let m = a
    if b < m { m = b }
    if c < m { m = c }
    give m
}

proc levenshtein(a: string, b: string) -> i32
{
    if a == b { give 0 }
    if a.len == 0 { give b.len }
    if b.len == 0 { give a.len }

    let prev = empty_i32s()
    let j: i32 = 0
    while j <= b.len
    {
        prev = prev.push(j)
        j = j + 1
    }

    let i: i32 = 1
    while i <= a.len
    {
        let cur = empty_i32s()
        cur = cur.push(i)
        let k: i32 = 1
        while k <= b.len
        {
            let cost: i32 = 1
            if a[i - 1] == b[k - 1] { cost = 0 }
            let ins = cur[k - 1] + 1
            let del = prev[k] + 1
            let sub = prev[k - 1] + cost
            cur = cur.push(min3(ins, del, sub))
            k = k + 1
        }
        prev = cur
        i = i + 1
    }

    give prev[b.len]
}

proc last_segment(name: string) -> string
{
    if not str.contains(name, ".") { give name }
    let p = str.split(name, ".")
    if p.len == 0 { give name }
    give p[p.len - 1]
}

proc suggest_packages(name_in: string, max_items: i32, pool: [string]) -> [string]
{
    if max_items <= 0 { give empty_strings() }

    let name = unquote(name_in)
    let tail = last_segment(name)

    let out = empty_strings()
    let max_score: i32 = 3

    while out.len < max_items
    {
        let best = ""
        let best_score: i32 = 9999
        let best_pref = false
        let best_cont = false
        let best_std = false

        let c: string = ""
        let i: i32 = 0
        while i < pool.len
        {
            c = pool[i]
            if list_has(out, c)
            {
                i = i + 1
                continue
            }

            let pref = str.starts_with(c, name)  or  str.starts_with(c, tail)
            let cont = str.contains(c, name)  or  str.contains(c, tail)
            let d1 = levenshtein(name, c)
            let d2 = levenshtein(tail, c)
            let d = d1
            if d2 < d { d = d2 }
            let std = pkg_is_stdlib(c)

            let pick = false
            if d < best_score { pick = true }
            else if d == best_score
            {
                if std  and  not best_std { pick = true }
                else if std == best_std  and  pref  and  not best_pref { pick = true }
                else if std == best_std  and  pref == best_pref  and  cont  and  not best_cont { pick = true }
            }

            if pick
            {
                best = c
                best_score = d
                best_pref = pref
                best_cont = cont
                best_std = std
            }
            i = i + 1
        }

        if best == "" { break }
        if not best_pref  and  not best_cont  and  best_score > max_score { break }
        out = out.push(best)
    }

    give out
}

proc quoted_list(items: [string]) -> string
{
    let q = empty_strings()
    let s: string = ""
    let i: i32 = 0
    while i < items.len
    {
        s = items[i]
        q = q.push("'" + s + "'")
        i = i + 1
    }
    give str.join(q, ", ")
}

proc attach_package_suggestion_fixes(d: diagnostics.Diagnostic, s: [string]) -> diagnostics.Diagnostic
{
    let out = d
    let max_fx = quickfix_limit()
    let i: i32 = 0
    while i < s.len  and  i < max_fx
    {
        out = diagnostics.with_quick_fix(out, "replace", "Replace package with '" + s[i] + "'", s[i])
        i = i + 1
    }
    give out
}

proc attach_package_suggestion_related(d: diagnostics.Diagnostic, file: string, line: i32, col: i32, s: [string]) -> diagnostics.Diagnostic
{
    let out = d
    let it: string = ""
    let i: i32 = 0
    while i < s.len
    {
        it = s[i]
        out = diagnostics.with_related(out, file, line, col, "candidate package: " + it)
        i = i + 1
    }
    give out
}

proc collect_undeclared_calls(n: parser.AstNode, sym: symbol_table.SymbolTable, file: string) -> [diagnostics.Diagnostic]
{
    let out = empty_diagnostics()

    if n.kind == "function_call"
    {
        let called = n.value
        if called != ""  and  not symbol_exists(sym, called)
        {
            let d = diagnostics.new("DOTS0003", "undeclared symbol: " + called, file, n.line, n.col, n.line, n.col + called.len, "semantic")
            let d2 = diagnostics.with_quick_fix(d, "define", "Add missing function", "fn." + last_qualified_segment(called))
            out = out.push(d2)
        }
    }

    let child: parser.AstNode = n
    let child_i: i32 = 0
    while child_i < n.children.len
    {
        child = n.children[child_i]
        let d3_items = collect_undeclared_calls(child, sym, file)
        let d3_i: i32 = 0
        while d3_i < d3_items.len
        {
            let d3: diagnostics.Diagnostic = d3_items[d3_i]
            out = out.push(d3)
            d3_i = d3_i + 1
        }
        child_i = child_i + 1
    }

    give out
}

proc check_duplicates(sym: symbol_table.SymbolTable) -> [diagnostics.Diagnostic]
{
    let out = empty_diagnostics()
    let i: i32 = 0
    while i < sym.symbols.len
    {
        let a = sym.symbols[i]
        let j: i32 = i + 1
        while j < sym.symbols.len
        {
            let b = sym.symbols[j]
            if a.name == b.name  and  a.scope_id == b.scope_id
            {
                let d = diagnostics.new("DOTS0003", "duplicate symbol: " + a.name, a.file, b.line, b.col, b.line, b.col + a.name.len, "semantic")
                let d2 = diagnostics.with_related(d, a.file, a.line, a.col, "first declaration here")
                out = out.push(d2)
            }
            j = j + 1
        }
        i = i + 1
    }
    give out
}

proc check_undeclared_calls(root: parser.AstNode, sym: symbol_table.SymbolTable, file: string) -> [diagnostics.Diagnostic]
{
    let out = empty_diagnostics()
    let n: parser.AstNode = root
    let i: i32 = 0
    while i < root.children.len
    {
        n = root.children[i]
        let d_items = collect_undeclared_calls(n, sym, file)
        let d_i: i32 = 0
        while d_i < d_items.len
        {
            out = out.push(d_items[d_i])
            d_i = d_i + 1
        }
        i = i + 1
    }
    give out
}

proc check_package_imports(root: parser.AstNode, file: string) -> [diagnostics.Diagnostic]
{
    let out = empty_diagnostics()
    let pool = package_candidate_pool()
    let n: parser.AstNode = root
    let i: i32 = 0
    while i < root.children.len
    {
        n = root.children[i]
        if n.kind == "use_stmt"  or  n.kind == "import_stmt"
        {
            let pkg = n.value
            if not resolver.has_package(pkg, "")
            {
                let s = suggest_packages(pkg, suggestion_limit(), pool)
                let msg = "missing package: " + pkg
                if s.len == 1
                {
                    msg = msg + " (did you mean '" + s[0] + "'?)"
                }
                if s.len > 1
                {
                    msg = msg + " (did you mean " + quoted_list(s) + "?)"
                }

                let d = diagnostics.new("DOTS0003", msg, file, n.line, n.col, n.line, n.col + pkg.len, "semantic")
                let d2 = diagnostics.with_quick_fix(d, "manifest", "Set vitte package root", "\"vitte_packages_root\":\"../vitte/src/vitte/packages\"")
                let d3 = attach_package_suggestion_fixes(d2, s)
                let d4 = attach_package_suggestion_related(d3, file, n.line, n.col, s)
                out = out.push(d4)
            }
        }
        i = i + 1
    }
    give out
}

proc check_control_flow(root: parser.AstNode, file: string) -> [diagnostics.Diagnostic]
{
    let out = empty_diagnostics()
    let has_fn = false
    let n: parser.AstNode = root
    let i: i32 = 0
    while i < root.children.len
    {
        n = root.children[i]
        if n.kind == "function_def" { has_fn = true }
        if n.kind == "return_stmt"  and  not has_fn
        {
            let d = diagnostics.new("DOTS0003", "return outside function", file, n.line, n.col, n.line, n.col + 3, "semantic")
            let d2 = diagnostics.with_quick_fix(d, "wrap", "Declare function", "fn.main")
            out = out.push(d2)
        }
        if n.kind == "throw_stmt"  and  n.children.len == 0
        {
            let d3 = diagnostics.new("DOTS0003", "throw requires expression", file, n.line, n.col, n.line, n.col + 5, "semantic")
            let d4 = diagnostics.with_quick_fix(d3, "insert", "Add throw value", "throw.\"error\"")
            out = out.push(d4)
        }
        i = i + 1
    }
    give out
}

proc analyze(text: string, file: string) -> AnalysisResult
{
    let parsed = parser.parse(text)
    let root_scope = scope.root()
    let symbols = resolver.collect_declarations(parsed.root, file, root_scope.id)

    let diags = parsed.diagnostics
    let d_items = check_duplicates(symbols)
    let di: i32 = 0
    while di < d_items.len
    {
        diags = diags.push(d_items[di])
        di = di + 1
    }
    let d2_items = check_undeclared_calls(parsed.root, symbols, file)
    let di2: i32 = 0
    while di2 < d2_items.len
    {
        diags = diags.push(d2_items[di2])
        di2 = di2 + 1
    }
    let d3_items = check_package_imports(parsed.root, file)
    let di3: i32 = 0
    while di3 < d3_items.len
    {
        diags = diags.push(d3_items[di3])
        di3 = di3 + 1
    }
    let d4_items = check_control_flow(parsed.root, file)
    let di4: i32 = 0
    while di4 < d4_items.len
    {
        diags = diags.push(d4_items[di4])
        di4 = di4 + 1
    }

    give AnalysisResult(diags.len == 0, symbols, diags)
}

proc snapshot_json(res: AnalysisResult) -> string
{
    let s = ""
    let i: i32 = 0
    while i < res.symbols.symbols.len
    {
        if i > 0 { s = s + "," }
        let x = res.symbols.symbols[i]
        s = s + "{\"name\":\"" + x.name + "\",\"kind\":\"" + x.kind + "\",\"file\":\"" + x.file + "\",\"line\":" + str.from_i64(x.line) + ",\"col\":" + str.from_i64(x.col) + "}"
        i = i + 1
    }

    give "{\"schema_version\":\"1.1.0\",\"ok\":" + str.from_bool(res.ok) + ",\"symbols\":[" + s + "]}"
}
