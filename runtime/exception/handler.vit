space runtime/exception/handler

use runtime/common/result
use runtime/common/log
use runtime/common/events
use runtime/exception/exception
use runtime/exception/stacktrace

form Handler
{
    scope: string
    strict: bool
}

proc new(scope: string, strict: bool) -> Handler
{
    if scope == "" { scope = "runtime" }
    give Handler(scope, strict)
}

proc capture(h: Handler, ex: exception.Exception, st: stacktrace.StackTrace) -> result.RuntimeResult
{
    let msg = exception.summary(ex)
    if stacktrace.top(st) != ""
    {
        msg = msg + " top=" + stacktrace.top(st)
    }
    log.record("error", "runtime.exception", msg)
    events.append("exception", "error", h.scope + ":" + ex.code)
    if h.strict  and  ex.code == result.E_PANIC
    {
        give result.err(ex.code, msg, false)
    }
    give result.err(ex.code, msg, ex.retryable)
}
