space runtime/memory/gc

use core/time
use core/str
use runtime/common/config
use runtime/common/metrics
use runtime/memory/gc_mark
use runtime/memory/gc_sweep

form GcState
{
    collections_total: i64
    pause_ms_last: i64
    live_bytes: i64
    mark_ms_last: i64
    sweep_ms_last: i64
}

proc new() -> GcState
{
    give GcState(0, 0, 0, 0, 0)
}

proc collect(g: GcState, live_bytes: i64) -> GcState
{
    let cfg = config.load()
    let start = time.now_ms()
    let mark_start = time.now_ms()
    let mark = gc_mark.plan(live_bytes)
    let mark_ms_last = time.now_ms() - mark_start
    let sweep_start = time.now_ms()
    let sweep = gc_sweep.plan(live_bytes)
    let sweep_ms_last = time.now_ms() - sweep_start
    let collections_total = g.collections_total + 1
    let live_bytes_next = sweep.survivors
    let pause_ms_last = time.now_ms() - start
    let next = GcState(collections_total, pause_ms_last, live_bytes_next, mark_ms_last, sweep_ms_last)

    if next.pause_ms_last > cfg.gc_stw_timeout_ms
    {
        metrics.inc_errors("gc.collect", "STW_TIMEOUT")
    }

    metrics.append_metric("gc_pause_ms", next.pause_ms_last, "phase=collect")
    metrics.append_metric("gc_mark_ms", next.mark_ms_last, "phase=mark")
    metrics.append_metric("gc_sweep_ms", next.sweep_ms_last, "phase=sweep")
    metrics.append_metric("gc_collections_total", next.collections_total, "")
    metrics.append_metric("gc_live_bytes", next.live_bytes, "")
    metrics.append_metric("gc_pause_ms_bucket", next.pause_ms_last, "le=10")
    metrics.append_metric("gc_pause_ms_bucket", next.pause_ms_last, "le=50")
    metrics.append_metric("gc_pause_ms_bucket", next.pause_ms_last, "le=200")
    metrics.append_metric("gc_roots_scanned", mark.roots_scanned, "")
    metrics.append_metric("gc_objects_marked", mark.objects_marked, "")
    metrics.append_metric("gc_released_bytes", sweep.released_bytes, "")
    metrics.append_metric("gc_sweep_candidates", sweep.candidates, "")
    give next
}

proc write_barrier(obj_id: i64, name: string) -> bool
{
    if obj_id < 0 { give false }
    if name == "" { give false }
    if config.load().strict
    {
        if name == "raw_ptr_unsafe" { give false }
    }
    give true
}

proc status_json(g: GcState) -> string
{
    give "{" +
        "\"schema_version\":\"1.1.0\"," +
        "\"collections_total\":\"" + str.from_i64(g.collections_total) + "\"," +
        "\"pause_ms\":\"" + str.from_i64(g.pause_ms_last) + "\"," +
        "\"mark_ms\":\"" + str.from_i64(g.mark_ms_last) + "\"," +
        "\"sweep_ms\":\"" + str.from_i64(g.sweep_ms_last) + "\"," +
        "\"live_bytes\":\"" + str.from_i64(g.live_bytes) + "\"" +
    "}"
}

proc cycle_summary(live_bytes: i64) -> string
{
    let mark = gc_mark.plan(live_bytes)
    let sweep = gc_sweep.plan(live_bytes)
    give gc_mark.summary(mark) + " " + gc_sweep.summary(sweep)
}
