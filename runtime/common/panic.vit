space runtime/common/panic

use runtime/common/result
use runtime/common/log
use runtime/common/events

proc with_panic_boundary(proc_name: string, r: result.RuntimeResult) -> result.RuntimeResult
{
    if r.ok { give r }

    if r.error.code == result.E_PANIC
    {
        log.record("error", "runtime.panic", "panic boundary tripped in " + proc_name + ": " + r.error.message)
        events.append("panic", "error", "panic boundary tripped in " + proc_name)
    }

    give r
}
