.test.lsp.vitte.packages.snapshot.present.
.begin.
.sys.exec.capture."bash -lc 'test -f tests/snapshots/lsp/diagnostics_vitte_package.snapshot.json  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

.test.lsp.vitte.packages.diagnostics_and_completion.contract.
.begin.
.sys.exec.capture."bash -lc 'rg -n \"DOTS004|missing vitte package|vitte package|Package resolved from ../vitte/src/vitte/packages\" lsp/diagnostics.vit lsp/completion.vit  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

.test.lsp.vitte.packages.snapshot.shape.
.begin.
.sys.exec.capture."bash -lc 'grep -q \"\\\"jsonrpc\\\":\\\"2.0\\\"\" tests/snapshots/lsp/diagnostics_vitte_package.snapshot.json  and  grep -q \"DOTS004\" tests/snapshots/lsp/diagnostics_vitte_package.snapshot.json  and  grep -q \"missing vitte package\" tests/snapshots/lsp/diagnostics_vitte_package.snapshot.json  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

.test.lsp.vitte.packages.code_actions.quickfix.contract.
.begin.
.sys.exec.capture."bash -lc 'rg -n \"DOTS004|Replace package with|did you mean|package_quickfix_limit\" lsp/code_actions.vit lsp/diagnostics.vit  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.
