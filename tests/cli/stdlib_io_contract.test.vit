.test.cli.stdlib.io.modules.present.
.begin.
.sys.exec.capture."bash -lc 'for f in stdlib/io/console.vit stdlib/io/input.vit stdlib/io/logger.vit stdlib/io/print.vit stdlib/io/terminal.vit; do test -s \"$f\"  or  exit 1; done; echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

.test.cli.stdlib.io.bridge.contract.
.begin.
.sys.exec.capture."bash -lc 'rg -n \"pull core/io|pull core/fs|pull core/process|pull core/time|io\\.print|io\\.read_stdin_all|fs\\.append_file|process\\.env|proc warn\\(|proc debug\\(|proc write_level\\(|proc error_and_log\\(|proc prefixed\\(|proc numbered\\(\" stdlib/io/*.vit  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.
