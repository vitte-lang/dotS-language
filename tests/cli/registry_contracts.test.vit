.test.cli.registry.no_alias_collision.
.begin.
.sys.exec.capture."bash scripts/ci_registry_gate.sh".$out.
.assert.contains.$out."registry gate ok".
.ret.
.end.

.test.cli.registry.each_command_has_usage_parse_validate_execute.
.begin.
.sys.exec.capture."bash -lc 'missing=0; for f in cmd/dots/*.vit; do b=$(basename $f); if [ $b = main.vit ]  or  [ $b = registry.vit ]  or  [ $b = _command_template.vit ]; then continue; fi; rg -q ^proc\ usage\( $f  or  { echo missing_usage:$f; missing=1; }; rg -q ^proc\ parse\( $f  or  { echo missing_parse:$f; missing=1; }; rg -q ^proc\ validate\( $f  or  { echo missing_validate:$f; missing=1; }; rg -q ^proc\ execute\( $f  or  { echo missing_execute:$f; missing=1; }; done; if [ $missing -eq 0 ]; then echo OK; fi'".$out.
.assert.contains.$out."OK".
.ret.
.end.

.test.cli.registry.real_protocol_gate.
.begin.
.sys.exec.capture."bash scripts/ci_real_protocol_gate.sh".$out.
.assert.contains.$out."real protocol gate ok".
.ret.
.end.
