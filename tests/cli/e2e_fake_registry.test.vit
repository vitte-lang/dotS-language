.test.cli.e2e.fake_registry.install_success.
.begin.
.sys.exec.capture."bash -lc 'scripts/fake_registry.sh init .dots/e2e-reg; scripts/fake_registry.sh add-pkg .dots/e2e-reg demo 1.0.0; DOTS_REGISTRY_DIR=.dots/e2e-reg dots install --json demo'".$out.
.assert.contains.$out."\"command\":\"install\"".
.assert.contains.$out."\"failed\":\"0\"".
.ret.
.end.

.test.cli.e2e.fake_registry.install_retry_deterministic.
.begin.
.sys.exec.capture."bash -lc 'scripts/fake_registry.sh init .dots/e2e-reg; scripts/fake_registry.sh add-pkg .dots/e2e-reg retrypkg 1.0.0; scripts/fake_registry.sh set-fail .dots/e2e-reg install 1; DOTS_REGISTRY_DIR=.dots/e2e-reg dots install --json --retries 2 retrypkg'".$out.
.assert.contains.$out."\"command\":\"install\"".
.assert.contains.$out."\"failed\":\"0\"".
.ret.
.end.

.test.cli.e2e.fake_registry.circuit_breaker.
.begin.
.sys.exec.capture."bash -lc 'scripts/fake_registry.sh init .dots/e2e-reg; scripts/fake_registry.sh add-pkg .dots/e2e-reg cbreak 1.0.0; scripts/fake_registry.sh set-fail .dots/e2e-reg install 5; DOTS_REGISTRY_DIR=.dots/e2e-reg dots install --json --retries 1 --cb-threshold 1 cbreak'".$out.
.assert.contains.$out."CIRCUIT_OPEN".
.ret.
.end.

.test.cli.e2e.fake_registry.publish_success.
.begin.
.sys.exec.capture."bash -lc 'scripts/fake_registry.sh init .dots/e2e-reg; reg=\"$(pwd)/.dots/e2e-reg\"; rm -rf .dots/e2e-pub; mkdir -p .dots/e2e-pub; printf \"{\\\"name\\\":\\\"demo\\\",\\\"version\\\":\\\"1.0.0\\\",\\\"license\\\":\\\"MIT\\\"}\\n\" > .dots/e2e-pub/dots.json; printf \"# changelog\\n\" > .dots/e2e-pub/CHANGELOG.md; (cd .dots/e2e-pub && DOTS_REGISTRY_MODE=fake DOTS_REGISTRY_DIR=\"$reg\" DOTS_PUBLISH_SKIP_GIT=1 dots publish --json --tag next)'".$out.
.assert.contains.$out."\"command\":\"publish\"".
.assert.contains.$out."\"tag\":\"next\"".
.ret.
.end.
