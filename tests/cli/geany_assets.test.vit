.test.cli.geany.assets.gate.
.begin.
.sys.exec.capture."bash scripts/ci_geany_assets_gate.sh".$out.
.assert.contains.$out."geany assets gate ok".
.ret.
.end.

.test.cli.geany.snapshots.match.
.begin.
.sys.exec.capture."bash -lc 'cmp -s editor/geany/filedefs/filetypes.DOTS.conf tests/snapshots/geany/filetypes.DOTS.conf.snapshot && cmp -s editor/geany/filedefs/filetypes.VIT.conf tests/snapshots/geany/filetypes.VIT.conf.snapshot && cmp -s editor/geany/filedefs/snippets.DOTS.conf tests/snapshots/geany/snippets.DOTS.conf.snapshot && cmp -s editor/geany/filedefs/snippets.VIT.conf tests/snapshots/geany/snippets.VIT.conf.snapshot && cmp -s editor/geany/tools/geany.conf tests/snapshots/geany/geany.conf.snapshot && cmp -s editor/geany/tools/keybindings.conf tests/snapshots/geany/keybindings.conf.snapshot && cmp -s editor/geany/tools/plugins/geanylsp.conf tests/snapshots/geany/geanylsp.conf.snapshot && cmp -s editor/geany/profiles/dotS-language.runtime.geany tests/snapshots/geany/dotS-language.runtime.geany.snapshot && cmp -s editor/geany/profiles/dotS-language.strict-runtime.geany tests/snapshots/geany/dotS-language.strict-runtime.geany.snapshot && echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.
