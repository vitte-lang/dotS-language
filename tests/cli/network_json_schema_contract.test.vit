.test.cli.network_json_contract.install_update_publish_fields.
.begin.
.sys.exec.capture."bash -lc 'scripts/fake_registry.sh init .dots/e2e-net-contract >/dev/null; scripts/fake_registry.sh add-pkg .dots/e2e-net-contract netpkg 1.0.0 >/dev/null; DOTS_REGISTRY_MODE=fake DOTS_REGISTRY_DIR=.dots/e2e-net-contract dots install --json netpkg >/tmp/net_install.json; DOTS_REGISTRY_MODE=fake DOTS_REGISTRY_DIR=.dots/e2e-net-contract dots update --json >/tmp/net_update.json; reg=\"$(pwd)/.dots/e2e-net-contract\"; rm -rf .dots/e2e-net-pub; mkdir -p .dots/e2e-net-pub; printf \"{\\\"name\\\":\\\"netpub\\\",\\\"version\\\":\\\"1.0.0\\\",\\\"license\\\":\\\"MIT\\\"}\\n\" > .dots/e2e-net-pub/dots.json; printf \"# c\\n\" > .dots/e2e-net-pub/CHANGELOG.md; (cd .dots/e2e-net-pub  and  DOTS_REGISTRY_MODE=fake DOTS_REGISTRY_DIR=\"$reg\" DOTS_PUBLISH_SKIP_GIT=1 dots publish --json --tag next >/tmp/net_publish.json); for f in /tmp/net_install.json /tmp/net_update.json /tmp/net_publish.json; do grep -q \"\\\"schema_version\\\":\\\"1.1.0\\\"\" \"$f\"  or  exit 1; grep -q \"\\\"error_type\\\":\" \"$f\"  or  exit 1; grep -q \"\\\"error_message\\\":\" \"$f\"  or  exit 1; grep -q \"\\\"run_id\\\":\" \"$f\"  or  exit 1; grep -q \"\\\"request_id\\\":\" \"$f\"  or  exit 1; done; echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

