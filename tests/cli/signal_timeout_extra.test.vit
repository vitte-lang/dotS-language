.test.cli.signal.sigint.contract.
.begin.
.sys.exec.capture."bash -lc 'dots run --watch src/main.dotS & pid=$!; sleep 1; kill -INT $pid; wait $pid || true'".$out.
.assert.contains.$out."interrupted".
.ret.
.end.

.test.cli.signal.sigterm.contract.
.begin.
.sys.exec.capture."bash -lc 'dots run --watch src/main.dotS & pid=$!; sleep 1; kill -TERM $pid; wait $pid || true'".$out.
.assert.contains.$out."interrupted".
.ret.
.end.

.test.cli.timeout.cooperative.contract.
.begin.
.assert.parse.ok."dots run --watch --timeout-ms 50 src/main.dotS".
.ret.
.end.
