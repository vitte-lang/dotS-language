.test.cli.package.artifact.modules.present.
.begin.
.sys.exec.capture."bash -lc 'test -f packaging/artifact.vit  and  test -f packaging/build.vit  and  test -f packaging/installer.vit  and  test -f packaging/publish.vit  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

.test.cli.package.command.uses.artifact.pipeline.
.begin.
.sys.exec.capture."bash -lc 'rg -n \"artifact\\.pack|artifact\\.verify|artifact\\.unpack|--file|--out-dir\" cmd/dots/package.vit packaging/*.vit  and  echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.
