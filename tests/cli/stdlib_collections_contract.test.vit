.test.cli.stdlib.collections.modules.present.
.begin.
.sys.exec.capture."bash -lc 'for f in stdlib/collections/list.vit stdlib/collections/set.vit stdlib/collections/queue.vit stdlib/collections/map.vit stdlib/collections/graph.vit; do test -s \"$f\" || exit 1; done; echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.

.test.cli.stdlib.collections.contract.
.begin.
.sys.exec.capture."bash -lc 'rg -n \"use core/str as str|use stdlib/collections/list as list|use stdlib/system/result as result|proc empty\(|proc is_empty\(|proc push\(|proc pop\(|proc pop_or\(|proc slice\(|proc unique\(|proc sort_asc\(|proc sort_desc\(|proc concat\(|proc extend\(|proc reverse\(|proc count\(|proc remove_first\(|proc remove_all\(|proc insert\(|proc insert_result\(|proc contains\(|form Queue|proc enqueue\(|proc enqueue_many\(|proc dequeue\(|proc dequeue_n\(|proc peek\(|proc clear\(|proc to_list\(|proc dequeue_result\(|form Map|proc set\(|proc get\(|proc delete\(|proc items\(|proc keys\(|proc values\(|proc get_or\(|proc size\(|proc merge\(|proc copy\(|proc update\(|proc from_items\(|proc pop_result\(|proc add_result\(|form Graph|proc add_edge\(|proc remove_edge\(|proc edge_count\(|proc node_count\(|proc neighbors\(|proc has_edge\(|proc degree_out\(|proc degree_in\(|proc nodes\(|proc add_edge_result\(|proc is_subset\(|proc is_superset\(|proc symmetric_difference\(|proc is_disjoint\(|proc equals\(" stdlib/collections/*.vit && echo ok'".$out.
.assert.contains.$out."ok".
.ret.
.end.
