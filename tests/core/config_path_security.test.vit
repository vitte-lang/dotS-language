.test.core.config.path.validation.
.begin.
.assert.config.path.ok."./cache".
.assert.config.path.ok."/workspace/project/.dots-cache".
.assert.config.path.fail."../secret".
.assert.config.path.fail."..\\secret".
.ret.
.end.

.test.core.config.url.validation.
.begin.
.assert.config.url.ok."https://registry.example.invalid:443".
.assert.config.url.ok."http://localhost:8080".
.assert.config.url.fail."ftp://registry".
.assert.config.url.fail."https://".
.assert.config.url.fail."https://host:99999".
.ret.
.end.

.test.core.config.secret.redaction.
.begin.
.assert.config.redaction.ok."api_token=***REDACTED***".
.ret.
.end.
