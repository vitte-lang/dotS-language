.test.core.config.env.bool.parsers.
.begin.
.assert.env.bool.ok."DOTS_CONFIG_STRICT=true".
.assert.env.bool.ok."DOTS_CONFIG_STRICT=false".
.assert.env.bool.ok."DOTS_CONFIG_STRICT=1".
.assert.env.bool.ok."DOTS_CONFIG_STRICT=0".
.assert.env.bool.ok."DOTS_CONFIG_STRICT=on".
.assert.env.bool.ok."DOTS_CONFIG_STRICT=off".
.assert.env.bool.fail."DOTS_CONFIG_STRICT=maybe".
.ret.
.end.

.test.core.config.env.int.duration.bytes.parsers.
.begin.
.assert.env.int.ok."DOTS_WORKERS=16".
.assert.env.int.fail."DOTS_WORKERS=-2".
.assert.env.duration.ok."DOTS_TIMEOUT_REQUEST=500ms".
.assert.env.duration.ok."DOTS_TIMEOUT_REQUEST=2s".
.assert.env.duration.ok."DOTS_TIMEOUT_REQUEST=1m".
.assert.env.duration.fail."DOTS_TIMEOUT_REQUEST=1h".
.assert.env.bytes.ok."DOTS_CACHE_MAX=64KB".
.assert.env.bytes.ok."DOTS_CACHE_MAX=10MB".
.assert.env.bytes.fail."DOTS_CACHE_MAX=wat".
.ret.
.end.

.test.core.config.env.empty.partial.invalid.
.begin.
.assert.env.snapshot.ok."empty".
.assert.env.snapshot.ok."partial".
.assert.env.snapshot.warn."invalid fallback applied".
.ret.
.end.
