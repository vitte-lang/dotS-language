.test.core.parser.pratt.precedence.
.begin.
.assert.parse.ok."set.$x.call.add.1.2".
.assert.ast.has."assignment_set".
.assert.ast.has."function_call".
.ret.
.end.

.test.core.parser.decl_stmt_expr.separation.
.begin.
.assert.parse.ok."fn.main.$arg\ncall.main.$arg".
.assert.ast.has."function_def".
.assert.ast.has."stmt_expr".
.ret.
.end.

.test.core.parser.recovery.sync.
.begin.
.assert.parse.diag."DOTS0002".
.assert.parse.recovers.next_line.
.ret.
.end.

.test.core.parser.keyword.typo.suggestion.
.begin.
.assert.parse.diag."did you mean".
.ret.
.end.
