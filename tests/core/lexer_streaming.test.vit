.test.core.lexer.tokens.strict.with_span_trivia.
.begin.
.assert.lex.ok."set.$x.1".
.assert.token.kind."keyword".
.assert.token.span.present.
.assert.token.trivia.present.
.ret.
.end.

.test.core.lexer.invalid_escape.recovery.
.begin.
.assert.lex.diag."DOTS0001".
.assert.lex.recovery.continues.
.ret.
.end.

.test.core.lexer.incremental.relex.window.
.begin.
.assert.relex.window.ok.
.assert.relex.tokens_total.gt0.
.ret.
.end.

.test.core.lexer.comment.newline.preserved.
.begin.
.assert.lex.ok."let.$x.1 # keep newline\nlet.$y.2".
.assert.token.kind."newline".
.ret.
.end.

.test.core.lexer.window.slice.text.
.begin.
.assert.relex.window.ok.
.assert.relex.tokens_total.gt0.
.ret.
.end.

.test.core.lexer.unknown_token.suggestion.
.begin.
.assert.lex.diag."did you mean".
.assert.lex.recovery.continues.
.ret.
.end.

.test.core.lexer.numeric.literal.advanced.forms.
.begin.
.assert.lex.ok."let.$x.1_000_000".
.assert.lex.ok."let.$x.0xFF".
.assert.lex.ok."let.$x.0b1010".
.assert.lex.ok."let.$x.0o755".
.assert.lex.ok."let.$x.6.02e23".
.ret.
.end.

.test.core.lexer.numeric.literal.invalid.forms.
.begin.
.assert.lex.diag."invalid".
.assert.lex.recovery.continues.
.ret.
.end.

.test.core.lexer.string.escape.hex_unicode.
.begin.
.assert.lex.ok."let.$s.\"a\\x41\\u0042\"".
.assert.lex.diag."invalid".
.assert.lex.recovery.continues.
.ret.
.end.
