.test.core.diagnostics.catalog.codes.stable.
.begin.
.assert.contains."DOTS0001".
.assert.contains."DOTS0002".
.assert.contains."DOTS0003".
.assert.contains."DOTS0004".
.ret.
.end.

.test.core.diagnostics.format.human_json_sarif.
.begin.
.assert.format.human.ok.
.assert.format.json.ok.
.assert.format.sarif.ok.
.assert.format.json.schema_version."1.1.0".
.ret.
.end.

.test.core.diagnostics.dedupe_sort_budget_diff.
.begin.
.assert.dedupe.by_identity.
.assert.sort.stable.severity_file_span.
.assert.budget.max_per_file.
.assert.budget.max_total.
.assert.diff.only_delta.
.ret.
.end.
