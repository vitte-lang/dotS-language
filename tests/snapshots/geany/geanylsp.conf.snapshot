[geanylsp]
enabled=true
log_level=info
log_file=.dots/logs/geanylsp.log
request_timeout_ms=4000
retry_count=2

[language:DOTS]
filetypes=dotS;vit
command=dots lsp --stdio
root_patterns=.git,dots.json,.dots,vit.mod
initialization_options={"diagnostics":{"severity":{"error":"Error","warn":"Warning","info":"Info","hint":"Hint"}},"runtime":{"strict":true}}

[fallback]
goto_definition_cmd=bash scripts/geany_goto_definition.sh "%w"
find_references_cmd=bash scripts/geany_find_references.sh "%w"
