[DOTS]
proc=proc ${name:main}(${args}) -> ${ret:i32}\n{\n    ${cursor}\n}\n
form=form ${name:Type}\n{\n    ${cursor}\n}\n
entry=entry at ${path:dots/cmd/${name}}\n{\n    give main()\n}\n
runtime_status=dots runtime status --json\n
runtime_doctor=dots runtime doctor --strict\n
runtime_events=dots runtime events --lines 100\n
runtime_trace=dots runtime trace\n
runtime_thread_test=.test.runtime.thread.lifecycle.strict.\n.begin.\n.assert.thread.state."new->running->joined".\n.ret.\n.end.\n
runtime_channel_test=.test.runtime.channel.invariants.\n.begin.\n.assert.channel.invariant.ok."sent==recv+buffered+dropped".\n.ret.\n.end.\n
runtime_mutex_test=.test.runtime.deadlock.watchdog.\n.begin.\n.assert.mutex.contention.backoff.\n.ret.\n.end.\n
runtime_jit_test=.test.runtime.jit.verify.cache.fallback.\n.begin.\n.assert.jit.verify.ir.before_compile.\n.ret.\n.end.\n
runtime_vm_test=.test.runtime.vm.safe_points.cancel.\n.begin.\n.assert.vm.safe_point.count.\n.ret.\n.end.\n
runtime_gc_test=.test.runtime.gc.metrics.quotas.\n.begin.\n.assert.gc.metrics.present.\n.ret.\n.end.\n
msg_ok_en=print_json_response_ex("1.1.0", "${command}", "ok", "", "", ["message"], ["ok"])\n
msg_err_en=print_json_response_ex("1.1.0", "${command}", "error", "${error_type}", "${error_message}", [], [])\n
msg_ok_fr=print_json_response_ex("1.1.0", "${command}", "ok", "", "", ["message"], ["succes"])\n
msg_err_fr=print_json_response_ex("1.1.0", "${command}", "error", "${error_type}", "${error_message}", [], [])\n
