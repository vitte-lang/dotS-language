[project]
name=dotS-language-perf
base_path=/home/vincent/Documents/GitHub/dotS-language
description=Perf profile (stress benches, reduced verbosity)
file_patterns=*.dotS;*.vit;*.md;*.sh

[env]
DOTS_BENCH_MODE=stress
DOTS_BENCH_OUTPUT=human
DOTS_CLI_STRICT=0

[build-menu]
FT_00_LB=Bench stress
FT_00_CM=DOTS_BENCH_MODE=stress bash scripts/bench.sh run-all
FT_00_WD=%p
FT_01_LB=Startup bench
FT_01_CM=bash scripts/cli_startup_bench.sh 20 120
FT_01_WD=%p
