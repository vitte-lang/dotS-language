[project]
name=dotS-language-docs
base_path=/home/vincent/Documents/GitHub/dotS-language
description=Docs profile (md/html/json)
file_patterns=*.dotS;*.vit;*.md;*.sh

[build-menu]
FT_00_LB=Doc md
FT_00_CM=dots doc --format md
FT_00_WD=%p
FT_01_LB=Doc html
FT_01_CM=dots doc --format html
FT_01_WD=%p
FT_02_LB=Doc json
FT_02_CM=dots doc --format json --json
FT_02_WD=%p
