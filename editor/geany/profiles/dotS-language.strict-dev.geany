[project]
name=dotS-language-strict-dev
base_path=/home/vincent/Documents/GitHub/dotS-language
description=Strict dev profile (DOTS_CLI_STRICT=1, fake registry)
file_patterns=*.dotS;*.vit;*.md;*.sh

[env]
DOTS_CLI_STRICT=1
DOTS_REGISTRY_MODE=fake

[build-menu]
FT_00_LB=Run (strict)
FT_00_CM=DOTS_CLI_STRICT=1 DOTS_REGISTRY_MODE=fake dots run "%f"
FT_00_WD=%p
FT_01_LB=Lint
FT_01_CM=dots lint --format json "%f"
FT_01_WD=%p
FT_02_LB=Fmt
FT_02_CM=dots fmt --write "%f"
FT_02_WD=%p
